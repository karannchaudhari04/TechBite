# ── DATABASE WRITER (PRIMARY) ────────────────────────────────────────────────
DATABASE_WRITER_URL=jdbc:mysql://<tidb-primary-host>:4000/techbite?useSSL=true&serverTimezone=UTC
DATABASE_WRITER_USER=your_db_writer_user
DATABASE_WRITER_PASSWORD=your_db_writer_password

# ── DATABASE READER (REPLICA) ────────────────────────────────────────────────
DATABASE_REPLICA_URL=jdbc:mysql://<tidb-replica-host>:4000/techbite?useSSL=true&serverTimezone=UTC
DATABASE_REPLICA_USER=your_db_replica_user
DATABASE_REPLICA_PASSWORD=your_db_replica_password

# ── REDIS CONFIGURATION ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── AI ENGINE (GOOGLE GEMINI) ────────────────────────────────────────────────
# API Keys for summary ingestion and premium simplified explanations
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EXPLAIN_API_KEY=your_gemini_explain_api_key_here

# ── MOBILE DEEP LINK VERIFICATION ────────────────────────────────────────────
# Used by /.well-known/assetlinks.json for Android App Links domain verification
ANDROID_SHA256_FINGERPRINT=71:BC:9C:71:07:82:E2:3C:F8:55:A2:33:16:F7:FA:4C:FF:18:E5:B0:08:AD:49:BC:60:09:47:43:1F:57:44:B3

# ── SECURITY & STATELSS AUTH ─────────────────────────────────────────────────
JWT_SECRET=generater_a_strong_random_jwt_signing_secret_here
PORT=8080

# ── FIREBASE AUTHENTICATION CONFIGURATION ─────────────────────────────────────
# Option A: Path to local service account JSON file (for local dev)
FIREBASE_CREDENTIALS_PATH=backend/src/main/resources/firebase-adminsdk.json

# Option B: Raw JSON service account string (for production/Render environment variable)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "techbite-app", ...}

# ── APP SWITCHES ─────────────────────────────────────────────────────────────
SQL_INIT_MODE=never
NEWS_INGESTION_ENABLED=true
