# ── API ENDPOINT CONFIGURATION ────────────────────────────────────────────────
# For Local Wireless Testing: Uncomment and replace with your laptop's local LAN IP
# EXPO_PUBLIC_API_URL=http://192.168.1.X:8080/api/v1

# For Production / Cloud Staging
EXPO_PUBLIC_API_URL=https://<your-render-app-name>.onrender.com/api/v1

# ── FIREBASE AUTHENTICATION CONFIGURATION ─────────────────────────────────────
# Replace these values with your Firebase Project Settings -> Web App configuration details
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_hash_id

# ── GOOGLE SIGN-IN OAUTH 2.0 CREDENTIALS ──────────────────────────────────────
# Obtain these client IDs from your Google Cloud Console Credentials page
# Web Client ID (Mandatory for overall Auth coordination)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here.apps.googleusercontent.com

# iOS Client ID (Required if building or testing on iOS)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id_here.apps.googleusercontent.com
